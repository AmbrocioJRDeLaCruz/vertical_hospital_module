<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="consulta_paciente" name="Consulta Paciente">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-set="sorted_docs" t-value="docs.sorted(lambda x: x.id)"/>
                <div class="page">
                    <t t-foreach="sorted_docs" t-as="o">
                        <div id="wrap">
                            <div class="container">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Secuencia</th>
                                            <th>Nombre</th>
                                            <th>RNC</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><span t-esc="o.sequence"/></td>
                                            <td><span t-esc="o.name"/></td>
                                            <td><span t-esc="o.rnc"/></td>
                                            <td><span t-esc="o.state"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>
